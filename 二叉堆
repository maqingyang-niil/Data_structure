#include <vector>
#include <utility>

template<typename T>
class BinaryHeap
{
public:
    explicit BinaryHeap(int size=100):array(size){}
    explicit BinaryHeap();
    explicit BinaryHeap(const std::vector<T>&x):array(x.size()+10),currentSize(x.size())
    {
        for (int i=0;i<x.size();++i)
            array[i+1]=x[i];
        bulidHeap();
    }
    void insert(const T &x)
    {
        if (currentSize=array.size()-1)
            array.resize(array.size()*2);
        int hole=++currentSize;
        T copy=x;
        array[0]=std::move(copy);
        for (;x<array[hole/2];hole/=2)
            array[hole]=std::move(array[hole/2]);
        array[hole]=std::move(array[0]);
    }
    void decreeseKey(int pos,int delt)
    {
        array[pos]=array[pos]-delt;
        T tmp=array[pos];
        int hole=pos;
        for (;tmp<array[hole];hole/=2)
            array[hole]=std::move(array[hole/2]);
        array[hole]=std::move(tmp);
    }
    void increaseKey(int pos,int delt)
    {
        array[pos]=array[pos]+delt;
        T tmp=array[pos];
        int hole=pos;
        int child=hole;
        for(;hole*2<currentSize;hole=child)
        {
            child=2*hole;
            if (child!=currentSize&&array[child+1]<array[child])
                ++child;
            if (array[child]<tmp)
                array[hole]=array[child];
            else
                break;
        }
        array[hole]=tmp;
    }
private:
    int currentSize;
    std::vector<T> array;
    void bulidHeap()
    {
        for (int i=currentSize/2;i>0;--i)
            percolateDown(i);
    }
    bool isEmpty()
    {
        return array.empty();
    }
    void deleteMin()
    {
        if (isEmpty())
            throw UnderflowException{};
        array[1]=std::move(array[currentSize--]);
        percolateDown(1);
    }
    void percolateUp(const T&x)
    {
        int hole=++currentSize;
        for (;x<array[hole];hole/=2)
            array[hole]=std::move(array[hole/2]);
        array[hole]=std::move(x);
    }
    void percolateDown(int hole)
    {
        int child=hole;
        T tmp=std::move(array[hole]);
        for (;hole*2<currentSize;hole=child)
        {
            child=hole*2;
            if (child!=currentSize&&array[child+1]<array[child])
                ++child;
            if (array[child]<tmp)
                array[hole]=std::move(array[child]);
            else
                break;
        }
        array[hole]=std::move(tmp);
    }
};
//算法6A
template<typename T>
T algrithm_6A(const std::vector<T>&x,int k,BinaryHeap<T> tmp)
{
    tmp(x);
    for (int i=k;i>0;--i)
        tmp.deleteMin();
    return tmp.accessMin();
}
//算法6B
template<typename T>
T algrithm_6B(const std::vector<T>&x,int k,BinaryHeap<T> tmp)
{
    std::vector<T> newVector(x.begin(),x.begin()+k);
    tmp(newVector);
    int buf=tmp.deleteMin();
    for (int i=k+1;i<x.size();++i)
    {
        if (x[i]>tmp.accessMin())
        {
            tmp.deleteMin();
            tmp.insert(x[i]);
        }
    }
    return tmp.accessMin();
}
