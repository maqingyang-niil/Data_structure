#include <utility>
#include <algorithm>
#include <vector>
#include <random>
template<typename AnyType>
class CuckooHashFamily
{
public:
    size_t hash(const AnyType&x,int which);
    int getNumberofFunction();
    void generateNewFunction();
};
template<typename Anytype,typename HashFamily>
class CuckooHashTable
{
public:
    explicit CuckooHashTable(int size=101):array(nextPrime(size))
    {
        numHashFunction=hashFunctions.getNumberofFunction();
        rehashes=0;
        makeEmpty();
    }
    void makeEmpty()
    {
        currentSize=0;
        for (auto&arr:array)
            arr.isActive=false;
    }
    int myhash(const Anytype&x,int which)
    {
        return hashFunctions.hash(x,which)%array.size();
    }
    bool isActive(int currentPos)
    {
        return array[currentPos].isActive==true;
    }

    int findPos(const Anytype&x)
    {
        for (int i=0;i<numHashFunction;++i)
        {
            int pos= myhash(x,i);
            if (isActive(pos)&&array[pos].element==x)
                return pos;
        }
        return -1;
    }
    bool contains(const Anytype&x)
    {
        return findPos(x)!=-1;
    }
    bool remove(const Anytype&x)
    {
        int pos= findPos(x);
        if (!isActive(pos))
            return false;
        array[pos].isActive=false;
        --currentSize;
        return true;
    }
    bool insertHelperl(const Anytype&xx)
    {
        const int COUNT_LIMIT=100;
        Anytype x=xx;
        while(true)
        {
            int lastpos=-1;
            int pos;
            for (int count=0;count<COUNT_LIMIT;++count)
            {
                for (int i=0;i<numHashFunction;i++)
                {
                    pos= myhash(x,i);
                    if(!isActive(pos))
                    {
                        array[pos]=std::move(HashEntry{std::move(x),true});
                        ++currentSize;
                        return true;
                    }
                }
                int i=0;
                do {
                    pos= myhash(x,r.nextInt(numHashFunction));
                }while(pos==lastpos&&i++<5);
                lastpos=pos;
                std::swap(x,array[pos].element);
            }
            if (++rehashes>ALLOWED_REHASHES)
            {
                expand();
                rehashes=0;
            }
            else
                rehash();
        }
    }
    bool inert(const Anytype&x)
    {
        if (contains(x))
            return false;
        if (currentSize>array.size()*MAX_LOAD)
            expand();
        return insertHelperl(x);
    }
    void expand()
    {
        rehash(static_cast<int>(array.size()/MAX_LOAD));
    }
    void rehash()
    {
        hashFunctions.generateNewFunction();
        rehashes(array.size());
    }
    void rehash(int newsize)
    {
        std::vector<HashEntry> oldarray=array;
        array.resize(nextPrime(newsize));
        for (auto& arr:array)
            arr.isActive=false;
        currentSize=0;
        for (auto&arr:array)
            if (arr.isActive)
                insert(std::move(arr.element));
    }
private:
    struct HashEntry
    {
    Anytype element;
    bool isActive;
    HashEntry(const Anytype&ele=Anytype{},bool a=false):element(ele),isActive(a){}
    HashEntry(const Anytype&&ele,bool a=false):element(std::move(ele)),isActive(a){}
    };
    bool isPrime(int num) {
        if (num <= 1)
        {
            return false;
        }
        if (num <= 3)
        {
            return true;
        }
        if (num % 2 == 0 || num % 3 == 0)
        {
            return false;
        }
        for (int i = 5; i * i <= num; i += 6)
        {
            if (num % i == 0 || num % (i + 2) == 0)
            {
                return false;
            }
        }
        return true;
    }
    int nextPrime(int num) {
        int nextNum = num + 1;
        while (!isPrime(nextNum)) {
            nextNum++;
        }
        return nextNum;
    }
    static const double constexpr MAX_LOAD=0.4;
    static const int ALLOWED_REHASHES=5;
    std::vector<HashEntry> array;
    int currentSize;
    int numHashFunction;
    int rehashes;
    Random r;
    CuckooHashFamily<Anytype> hashFunctions;
};
