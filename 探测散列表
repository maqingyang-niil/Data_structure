#include <vector>
#include <algorithm>
//探测散列表
template<typename key>
class hash
{
public:
    size_t operator()(const key&k)
    {
        size_t hashval=0;
        for (auto p:k)
            hashval=38*hashval+p;
        return hashval;
    }
};
template<typename HashObj>
class HashTable
{
public:
    void MakeEmpty()
    {
        CurrentSize=0;
        for (auto&one:array)
        {
            one.info=EMPTY;
        }
    }
    explicit HashTable(int size=101):array(nextPrime(size))
    {
        MakeEmpty();
    }
    enum EntryType{ACTIVE,EMPTY,DELETED};
private:
    struct HashEntry
    {
    HashObj element;
    EntryType info;
    HashEntry(const HashObj&ele=HashObj{},EntryType i=EMPTY):element(ele),info(i){}
    HashEntry(const HashObj&&ele,EntryType i=EMPTY):element(std::move(ele)),info(i){}
    };
    std::vector<HashEntry> array;
    int CurrentSize;
    bool isPrime(int num) {
        if (num <= 1)
        {
            return false;
        }
        if (num <= 3)
        {
            return true;
        }
        if (num % 2 == 0 || num % 3 == 0)
        {
            return false;
        }
        for (int i = 5; i * i <= num; i += 6)
        {
            if (num % i == 0 || num % (i + 2) == 0)
            {
                return false;
            }
        }
        return true;
    }
    int nextPrime(int num) {
        int nextNum = num + 1;
        while (!isPrime(nextNum)) {
            nextNum++;
        }
        return nextNum;
    }
    bool isActive(int pos)
    {
        return array[pos].info==ACTIVE;
    }
    int FindPos(const HashObj&x)
    {
        int offset=1;
        int currentPos= myHash(x);
        while(array[currentPos].info!=EMPTY&&array[currentPos].element!=x)
        {
            currentPos+=offset;
            offset+=2;
            if (currentPos>array.size())
                currentPos-=array.size();
        }
        return currentPos;
    }
    size_t myHash(const HashObj&x)
    {
        unsigned int hashVal=0;
        for (auto&ch:x)
        {
            hashVal=37*hashVal+ch;
        }
        return hashVal%CurrentSize;
    }
    bool insert(const HashObj&x)
    {
        int currentPos= FindPos(x);
        if (isActive(currentPos))
            return false;
        array[currentPos].info=ACTIVE;
        array[currentPos].element=x;
        if (++CurrentSize>array.size()/2)
            rehash();
        return true;
    }
    bool remove(const HashObj&x)
    {
        int currentPos= FindPos(x);
        if (!isActive(currentPos))
            return false;
        array[currentPos].info=DELETED;
        return true;
    }
    void rehash()
    {
        std::vector<HashEntry> oldarray=array;
        array.resize(nextPrime(2*oldarray.size()));
        for (auto&arr:array)
            arr.info=EMPTY;
        CurrentSize=0;
        for (auto&arr:oldarray)
            if (arr.info==ACTIVE)
                insert(arr.element);
    }
};
